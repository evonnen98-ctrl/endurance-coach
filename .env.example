# ─── Supabase ────────────────────────────────────────────────────────────────
# Find these in your Supabase project: Settings > API
# IMPORTANT: VITE_* vars are baked into the frontend bundle at build time.
# In Railway, set them as environment variables BEFORE triggering a deploy.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Anthropic ───────────────────────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Server ──────────────────────────────────────────────────────────────────
# Railway sets PORT automatically — do not override it in Railway env vars.
# For local dev, 3002 avoids common conflicts.
PORT=3002

# Set to "production" in Railway (add as an environment variable in the dashboard).
NODE_ENV=development
